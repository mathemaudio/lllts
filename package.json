{
	"name": "lllts",
	"version": "0.1.0",
	"description": "LLLTS: A self-testing, LLM-friendly language built on TypeScript",
	"main": "dist/LLLTS.lll.js",
	"bin": {
		"lllts": "./bin/lllts",
		"lllts-server": "./bin/lllts-server"
	},
	"type": "commonjs",
	"scripts": {
		"watch": "TSC_NONPOLLING_WATCHER=1 tsc --watch",
		"lll-server": "lllts --server start --port 54300 --projectPath . --projectClientLink http://localhost:1",
		"lll-check": "lllts --project tsconfig.json --entry src/LLLTS.lll.ts",
		"lll-check-verbose": "lllts --project tsconfig.json --entry src/LLLTS.lll.ts --verbose",
		"lll-example-check-quick": "lllts --project tsconfig.json --entry src/examples/MathObject.lll.ts",
		"lll-example-bad-many-functions": "lllts --project tsconfig.json --entry src/examples/intentionallyBadExampleTests/ClassUsingManyFunctions.ts",
		"lll-example-bad-rogue-top-level": "lllts --project tsconfig.json --entry src/examples/intentionallyBadExampleTests/RogueTopLevelViolationsEntry.ts",
		"build": "tsc",
		"ts-check": "tsc --noEmit",
		"i": "pnpm i",
		"install-lllts-global": "pnpm link --global"
	},
	"keywords": [
		"typescript",
		"compiler",
		"testing",
		"llm"
	],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"express": "^4.22.1",
		"ts-morph": "^21.0.1"
	},
	"devDependencies": {
		"@types/express": "^4.17.25",
		"@types/node": "^20.10.6",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.3.3"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}